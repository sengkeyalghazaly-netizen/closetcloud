# ClosetCloud — environment configuration (semua opsional untuk versi mock)
# Salin ke `.env` lalu isi bila ingin menyambungkan backend nyata.

# --- Kai (AI Chat Stylist) ---
# URL Edge Function / proxy server-side yang memegang Claude API key & enforce kuota.
# Kalau KOSONG, Kai otomatis memakai rule-engine lokal (tetap berfungsi, tanpa backend).
# Contoh: https://<project>.supabase.co/functions/v1/ai-stylist-chat
VITE_KAI_ENDPOINT=

# Model yang dipakai proxy Kai (diteruskan ke body request). Default: claude-sonnet-4-5
VITE_KAI_MODEL=claude-sonnet-4-5
